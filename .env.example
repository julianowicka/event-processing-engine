# Runtime
NODE_ENV=development

# HTTP server
PORT=3000
# Comma-separated allowed origins. Leave empty to allow all origins.
CORS_ORIGIN=

# SQLite
SQLITE_DB_PATH=data/app.sqlite

# Event worker
EVENT_WORKER_INTERVAL_MS=1000
EVENT_WORKER_LOCK_TIMEOUT_MS=30000
EVENT_WORKER_VERBOSE_LOGS=false
EVENT_RETRY_DELAY_MS=10000
